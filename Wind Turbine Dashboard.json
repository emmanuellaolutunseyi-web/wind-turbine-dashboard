    {
        "id": "8331c7fbf87c58fc",
        "type": "function",
        "z": "259f7c66243c7094",
        "name": "alarm func",
        "func": "let state = flow.get(\"state\") || \"RUNNING\";\nlet rpm = flow.get(\"rpm\") || 0;\n\nif (state === \"ESTOP\") {\n    msg.payload = \"EMERGENCY STOP ACTIVE\";\n    msg.color = \"darkred\";\n} else if (rpm > 1400) {\n    msg.payload = \"HIGH RPM WARNING\";\n    msg.color = \"red\";\n} else if (state === \"BRAKE\") {\n    msg.payload = \"BRAKE ENGAGED\";\n    msg.color = \"orange\";\n} else {\n    msg.payload = \"SYSTEM NORMAL\";\n    msg.color = \"green\";\n}\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
