    {
        "id": "fa86a0e64a554f65",
        "type": "function",
        "z": "259f7c66243c7094",
        "name": "Simulator",
        "func": "let state = flow.get(\"state\") || \"RUNNING\";\nlet rpm = flow.get(\"rpm\");\nlet wind = flow.get(\"wind\");\nlet power = flow.get(\"power\");\n\nif (rpm === undefined) rpm = 900;\nif (wind === undefined) wind = 11;\nif (power === undefined) power = 300;\n\nif (state === \"RUNNING\") {\n    wind = Math.max(5, Math.min(20, wind + (Math.random() * 2.4 - 1.2)));\n\n    let targetRpm = 700 + wind * 45;\n    rpm = rpm + (targetRpm - rpm) * 0.35 + (Math.random() * 60 - 30);\n    rpm = Math.max(250, Math.min(1600, rpm));\n\n    power = Math.round((rpm * wind) / 32);\n    power = Math.max(80, Math.min(1200, power));\n}\n\nif (state === \"BRAKE\") {\n    rpm = Math.max(0, rpm - 160);\n    power = Math.max(0, power - 90);\n}\n\nif (state === \"ESTOP\") {\n    rpm = 0;\n    power = 0;\n}\n\nflow.set(\"rpm\", rpm);\nflow.set(\"wind\", wind);\nflow.set(\"power\", power);\n\nlet now = new Date().toLocaleTimeString();\n\nreturn [\n    { payload: Math.round(rpm), topic: \"RPM\" },\n    { payload: Math.round(power), topic: \"Power\" },\n    { payload: wind.toFixed(1) + \" m/s\", topic: \"Wind Speed\" },\n    { payload: state, topic: \"State\" },\n    { payload: now, topic: \"Last Update\" }\n];",
        "outputs": 5,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 340,
        "y": 140,
